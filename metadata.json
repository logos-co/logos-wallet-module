{
  "name": "wallet_module",
  "version": "1.0.0",
  "description": "Wallet module using go-wallet-sdk C library",
  "author": "Logos Core Team",
  "type": "grpc",
  "category": "wallet",
  "main": "wallet_module_grpc",
  "dependencies": [],
  "include": [],
  "capabilities": [],

  "nix": {
    "external_libraries": [
      {
        "name": "gowalletsdk",
        "build_command": "make static-library",
        "go_build": true,
        "output_pattern": "build/libgowalletsdk.*"
      }
    ],
    "cmake": {
      "find_packages": ["Threads"],
      "extra_include_dirs": ["lib"]
    }
  }
}
